{
  "expo": {
    "name": "Fearless",
    "slug": "fearless-safety",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fearless",
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["central"],
          "bluetoothAlwaysPermission": "Fearless needs Bluetooth to connect to your safety bracelet"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Fearless needs your location to send emergency alerts with your coordinates."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Fearless uses motion data to verify emergency situations."
        }
      ]
    ],
    "android": {
      "package": "com.fearless.safety",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.SEND_SMS",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "extra": {
      "eas": {
        "projectId": "fearless-safety-2026"
      }
    }
  }
}
